```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
.mypy_cache/
.pytest_cache/
*.pyc
__pycache__/

# JavaScript/Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java specific
*.class
*.jar
*.war
.gradle/
build/

# C/C++ specific
*.exe
*.dll
*.so
*.a
*.out

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```