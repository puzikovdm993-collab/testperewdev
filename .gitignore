```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
target/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.PyInstaller/
.pytest_cache/
.mypy_cache/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```